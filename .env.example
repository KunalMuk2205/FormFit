# FormFit Hybrid Deployment Environment Template
# Copy this file to .env and fill in the values

# Frontend API URL (leave blank for localhost:5000)
# For the demo, use your ngrok HTTPS URL: https://<your-id>.ngrok-free.app
REACT_APP_API_URL=

# Backend Security
# Generate a secure random string for production
JWT_SECRET_KEY=formfit-super-secret-key-change-this-for-demo
